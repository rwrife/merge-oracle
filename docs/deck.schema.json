{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rwrife.github.io/merge-oracle/deck.schema.json",
  "title": "merge-oracle deck",
  "description": "Deck JSON consumed by the merge-oracle CLI. See docs/decks.md and the README 'Custom decks' section.",
  "type": "object",
  "required": ["id", "name", "method", "version", "cards"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema URL (informational)."
    },
    "id": {
      "type": "string",
      "description": "Registry id; must be alphanumeric with . _ - and unique across bundled + user decks.",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable deck name shown by `oracle decks`."
    },
    "method": {
      "type": "string",
      "description": "Divination method this deck belongs to (e.g. 'tarot', 'runes').",
      "enum": ["tarot", "runes"]
    },
    "version": {
      "type": "integer",
      "description": "Deck schema version. Only v1 is defined today.",
      "minimum": 1
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "description": "Deck entries. Card shape is validated per-method; see method-specific fields below.",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "description": "Tarot card (method='tarot').",
            "required": ["id", "name", "keywords", "upright", "reversed"],
            "additionalProperties": true,
            "properties": {
              "id": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
              "name": { "type": "string" },
              "keywords": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "upright": { "type": "string" },
              "reversed": { "type": "string" }
            }
          },
          {
            "type": "object",
            "description": "Rune (method='runes').",
            "required": ["id", "glyph", "name", "keywords", "upright", "reversed"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "glyph": { "type": "string", "minLength": 1 },
              "name": { "type": "string" },
              "keywords": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "upright": { "type": "string" },
              "reversed": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
